{
  "manifest_version": 3,
  "name": "AI Overview Blocker",
  "version": "1.0",
  "permissions": ["tabs", "storage"],
  "content_scripts": [
    {
      "matches": ["https://www.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "toggle.html",
    "default_title": "AI Overview Blocker"
  },
  "icons": {
    "16": "icons/extension_icon16.png",
    "32": "icons/extension_icon32.png",
    "48": "icons/extension_icon48.png",
    "128": "icons/extension_icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "Google_AI_Overviews_Blocker@zachbarnes.dev"
      },
    "gecko_android": {}
  }
}